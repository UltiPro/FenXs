@page
@model NewsModel
@{
    Layout = "_LayoutLogged";
    ViewData["Description"] = "- Admin Panel - News";
    ViewData["Login"] = @Model.user.Login;
    ViewData["FenXs-Stars"] = @Model.user.FenXs_stars;
}

<div class="row m-2">
    <a href="Index" class="btn btn-primary border border-dark">Back To Admin Panel</a>
</div>
<div class="row m-2 mt-3">
    <a href="/News/Add" class="btn btn-success border border-dark">Add News</a>
</div>
<div class="m-2 mt-3">
    <table class="table table-striped table-dark border border-light">
        <thead>
            <tr class="text-center">
                <th scope="col" class="border-end border-light">ID</th>
                <th scope="col" class="border-end border-light">Title</th>
                <th scope="col" class="border-end border-light">Text</th>
                <th scope="col" class="border-end border-light">Date</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var N in Model.ListOfNews)
            {
                <tr class="FenXs-Font-Smaller">
                    <th scope="row" class="text-center border-end border-light">@Html.DisplayFor(m => N.id)</th>
                    <td class="border-end border-light">@Html.DisplayFor(m => N.title)</td>
                    <td class="border-end border-light">@Html.DisplayFor(m => N.text)</td>
                    <td class="border-end border-light">@Html.DisplayFor(m => N.date)</td>
                    <td class="text-center">
                        <a asp-page="News/Edit" asp-page-handler="Edit" asp-route-id="@N.id"
                        class="link-success fw-bold FenXs-Text-NoShadow">Edit</a> |
                        <a asp-page="News/Delete" asp-page-handler="Delete" asp-route-id="@N.id"
                        class="link-danger fw-bold FenXs-Text-NoShadow">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>