@page
@model IndexModel
@{
    Layout = "_Layout";
    ViewBag.IsIndex = true;
}

<div class="container index-error FenXs-Font-Regular">
    @if (Model.ErrorBox)
    {
        <div class="alert bg-danger alert-dismissible border border-2 border-dark shadow-lg" role="alert">
            <span asp-validation-for="R.login" class="d-block"></span>
            <span asp-validation-for="R.email" class="d-block"></span>
            <span asp-validation-for="R.password" class="d-block"></span>
            <span asp-validation-for="R.c_password" class="d-block"></span>
            <span asp-validation-for="L.login" class="d-block"></span>
            <span asp-validation-for="L.password" class="d-block"></span>
            <span class="d-block">@Model.Info</span>
            <button type="button" class="btn-close position-absolute top-50 translate-middle-y" data-bs-dismiss="alert"
            aria-label="Close"></button>
        </div>
    }
    @if (Model.WarningBox)
    {
        <div class="alert bg-warning alert-dismissible border border-2 border-dark shadow-lg" role="alert">
            <span class="d-block">@Model.Info</span>
            <button type="button" class="btn-close position-absolute top-50 translate-middle-y" data-bs-dismiss="alert"
            aria-label="Close"></button>
        </div>
    }
    @if (Model.SuccessBox)
    {
        <div class="alert bg-success alert-dismissible border border-2 border-dark shadow-lg" role="alert">
            <span class="d-block">@Model.Info</span>
            <button type="button" class="btn-close position-absolute top-50 translate-middle-y" data-bs-dismiss="alert"
            aria-label="Close"></button>
        </div>
    }
</div>
<div id="SignInLoginInBox" class="container index-menu shadow-lg">
    <div class="row text-center index-menu-tab">
        <div id="LoginInSelector" class="col FenXs-Dark-Wooden rounded-top border border-end-0 border-2 border-dark">
            Login In
        </div>
        <div id="SignInSelector" class="col FenXs-Wooden rounded-top border border-2 border-dark">
            Sign In
        </div>
    </div>
    <div class="row FenXs-Wooden border border-top-0 border-2 border-dark rounded-bottom">
        <div id="LoginInBox" style="display:none">
            <div class="row index-menu-form">
                <div class="col-4 border-end border-2 border-dark">
                    <label asp-for="L.login" class="mt-4 p-1 w-100">Login</label>
                    <label asp-for="L.login" class="my-2 p-1 w-100">Password</label>
                </div>
                <div class="col-8">
                    <form method="post" onsubmit="return ValidateLoginIn()" asp-page-handler="Login">
                        <div class="form-group mt-4">
                            <input type="text" asp-for="L.login" class="form-control p-1 border border-dark"
                                placeholder="Your Login">
                        </div>
                        <div class="form-group my-2">
                            <input type="password" asp-for="L.password" class="form-control p-1 border border-dark"
                                placeholder="Your Password">
                        </div>
                        <div class="form-group my-2 mb-0">
                            <button type="submit" class="btn btn-success p-1 w-100 border border-dark">Login In</button>
                        </div>
                        <div class="form-group text-center small">
                            <a href="RestorePasswordOrLogin" class="link-light">Forget Your Password?</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div id="SignInBox">
            <div class="row index-menu-form">
                <div class="col-4 border-end border-2 border-dark">
                    <label asp-for="R.login" class="mt-3 p-1 w-100">Login</label>
                    <label asp-for="R.email" class="mt-2 p-1 w-100">E-Mail</label>
                    <label asp-for="R.password" class="mt-2 p-1 w-100">Password</label>
                    <label asp-for="R.c_password" class="mt-2 p-1 w-100">Confirm P.</label>
                    <button id="SignInInfoBtn" class="btn FenXs-Dark-Wooden-Btn btn-sm mt-2 p-1 w-100">Info</button>
                </div>
                <div class="col-8">
                    <form method="post" onsubmit="return ValidateSignIn()" asp-page-handler="Registration">
                        <div class="form-group mt-3">
                            <input type="text" asp-for="R.login" class="form-control form-control-sm border border-dark"
                                placeholder="e.g. Player007">
                        </div>
                        <div class="form-group mt-2">
                            <input type="email" asp-for="R.email"
                                class="form-control form-control-sm border border-dark"
                                placeholder="e.g. player007@gmail.com">
                        </div>
                        <div class="form-group mt-2">
                            <input type="password" asp-for="R.password"
                                class="form-control form-control-sm border border-dark" placeholder="Your Password">
                        </div>
                        <div class="form-group mt-2">
                            <input type="password" asp-for="R.c_password"
                                class="form-control form-control-sm border border-dark"
                                placeholder="Confirm Your Password">
                        </div>
                        <div class="form-group mt-2">
                            <button type="submit" class="btn btn-success btn-sm w-100 border border-dark">Sign
                                In</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="InfoBox" class="container index-menu FenXs-Wooden p-1 px-2 border border-2 border-dark rounded shadow-lg"
    style="display:none;">
    <ol class="FenXs-Font-Regular text-justify p-1 ps-3">
        <li class="pt-3">Login must start with a letter and end with a letter or a number. There may be a dash
            or the floor in the middle. Login must be between 3 and 15 characters long.</li>
        <li class="pt-3">Password must contain only letters and numbers and must be between 8 and 30 characters
            long.</li>
        <li class="pt-3">E-mail must conform to an international standard.</li>
    </ol>
    <button id="InfoBoxQuitBtn" class="float-bottom btn btn-danger btn-sm w-100 border border-dark">Quit</button>
</div>